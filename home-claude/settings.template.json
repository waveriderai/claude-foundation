{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/load-north-star.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/load-north-star.sh",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/load-north-star.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__CLAUDE_HOME__/hooks/re-anchor.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 __CLAUDE_HOME__/hooks/proof-gate.py",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "theme": "light",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 1
  }
}
